{
  "expo": {
    "name": "Diamond Stats",
    "slug": "diamond-stats",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#002D72"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.diamondstats.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#002D72"
      },
      "package": "com.diamondstats.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "diamondstats",
    "plugins": [
      "expo-router"
    ]
  }
}
